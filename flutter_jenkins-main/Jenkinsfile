pipeline {
    agent any

    environment {
        JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"
        ANDROID_HOME = "/var/lib/jenkins/Android/Sdk"
        ANDROID_SDK_ROOT = "/var/lib/jenkins/Android/Sdk"
        FLUTTER_HOME = "/var/lib/jenkins/flutter"

        PATH = "${FLUTTER_HOME}/bin:${JAVA_HOME}/bin:${ANDROID_HOME}/platform-tools:${ANDROID_HOME}/cmdline-tools/latest/bin:${env.PATH}"
    }

    stages {

        stage('Debug Info') {
            steps {
                sh 'whoami'
                sh 'pwd'
                sh 'ls -la'
                sh 'echo $PATH'
                sh 'ls -l /var/lib/jenkins/flutter/bin/flutter'
            }
        }

        stage('Flutter Doctor') {
            steps {
                sh '/var/lib/jenkins/flutter/bin/flutter doctor'
            }
        }

        stage('Clean Project') {
            steps {
                dir('register_system/backend/flutter_app') {
                    sh '/var/lib/jenkins/flutter/bin/flutter clean'
                }
            }
        }

        stage('Get Dependencies') {
            steps {
                dir('register_system/backend/flutter_app') {
                    sh '/var/lib/jenkins/flutter/bin/flutter pub get'
                }
            }
        }

        stage('Build APK') {
            steps {
                dir('register_system/backend/flutter_app') {
                    sh '/var/lib/jenkins/flutter/bin/flutter build apk --release'
                }
            }
        }

        stage('Archive APK') {
            steps {
                archiveArtifacts artifacts: 'register_system/backend/flutter_app/build/app/outputs/flutter-apk/*.apk', fingerprint: true
            }
        }
    }

    post {
        success {
            echo '✅ Build APK berhasil!'
        }
        failure {
            echo '❌ Build APK gagal!'
        }
    }       

    stage('TEST') {
    steps {
        sh 'echo JENKINSFILE TERBACA'
    }
}
}