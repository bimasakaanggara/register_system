pipeline {
    agent any

    environment {
        JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"
        ANDROID_HOME = "/var/lib/jenkins/Android/Sdk"
        ANDROID_SDK_ROOT = "/var/lib/jenkins/Android/Sdk"
        FLUTTER_HOME = "/var/lib/jenkins/flutter"

        PATH = "${FLUTTER_HOME}/bin:${JAVA_HOME}/bin:${ANDROID_HOME}/platform-tools:${ANDROID_HOME}/cmdline-tools/latest/bin:${env.PATH}"
    }

    stages {

        stage('Debug Info') {
            steps {
                sh 'whoami'
                sh 'pwd'
                sh 'ls -la'
                sh 'echo $PATH'
                sh 'echo $ANDROID_HOME'
                sh 'ls -l /var/lib/jenkins/flutter/bin/flutter'
            }
        }

        stage('Check Folder Structure') {
            steps {
                sh 'ls -R'
            }
        }

        stage('Flutter Doctor') {
            steps {
                sh 'flutter doctor -v'
            }
        }

        stage('Clean Project') {
            steps {
                dir('flutter_jenkins-main/backend/flutter_app') {
                    sh 'flutter clean'
                }
            }
        }

        stage('Get Dependencies') {
            steps {
                dir('flutter_jenkins-main/backend/flutter_app') {
                    sh 'flutter pub get'
                }
            }
        }

        stage('Build APK') {
            steps {
                dir('flutter_jenkins-main/backend/flutter_app') {
                    sh 'flutter build apk --release'
                }
            }
        }

        stage('Archive APK') {
            steps {
                archiveArtifacts artifacts: 'flutter_jenkins-main/backend/flutter_app/build/app/outputs/flutter-apk/*.apk', fingerprint: true
            }
        }

        stage('TEST') {
            steps {
                sh 'echo JENKINSFILE TERBACA ✅'
            }
        }
    }

    post {
        success {
            echo '✅ Build APK berhasil!'
        }
        failure {
            echo '❌ Build APK gagal!'
        }
    }
}